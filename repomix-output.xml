"use client";

import { Checkbox } from "@/components/ui/checkbox";
import type { FieldResponse } from "@/lib/api/fields";

export default function FieldTab({
  field,
}: {
  field?: FieldResponse | null;
}) {
  const meta = field?.meta as Record<string, unknown> | undefined;
  return (
    <div className="px-5 py-4">
      <div className="grid max-[770px]:grid-cols-1 grid-cols-2 gap-4">
        <div>
          <div className="mb-1.5 block text-sm font-medium text-[#111827]">Readonly</div>
          <label htmlFor="field-readonly" className="flex h-[54px] cursor-pointer items-center rounded-md border-2 border-[#E5E7EB] bg-white px-3 focus-within:border-primary">
            <Checkbox id="field-readonly" defaultChecked={!!meta?.readonly} />
            <span className="ml-2 truncate text-sm text-[#6B7280]">Disable the field in the app</span>
          </label>
        </div>

        <div>
          <div className="mb-1.5 block text-sm font-medium text-[#111827]">Required</div>
          <label htmlFor="field-required" className="flex h-[54px] cursor-pointer items-center rounded-md border-2 border-[#E5E7EB] bg-white px-3 focus-within:border-primary">
            <Checkbox id="field-required" defaultChecked={!!meta?.required} />
            <span className="ml-2 truncate text-sm text-[#6B7280]">Require value to be set on creation</span>
          </label>
        </div>

        <div>
          <div className="mb-1.5 block text-sm font-medium text-[#111827]">Hidden</div>
          <label htmlFor="field-hidden" className="flex h-[54px] cursor-pointer items-center rounded-md border-2 border-[#E5E7EB] bg-white px-3 focus-within:border-primary">
            <Checkbox id="field-hidden" defaultChecked={!!meta?.hidden} />
            <span className="ml-2 truncate text-sm text-[#6B7280]">Hidden on Detail</span>
          </label>
        </div>

        <div>
          <div className="mb-1.5 block text-sm font-medium text-[#111827]">Searchable</div>
          <label htmlFor="field-searchable" className="flex h-[54px] cursor-pointer items-center rounded-md border-2 border-[#E5E7EB] bg-white px-3 focus-within:border-primary">
            <Checkbox id="field-searchable" defaultChecked={!!meta?.searchable} />
            <span className="ml-2 truncate text-sm text-[#6B7280]">Include field in search queries</span>
          </label>
        </div>

        <div className="col-span-2">
          <label htmlFor="field-note" className="mb-1.5 block text-sm font-medium text-[#111827]">Note</label>
          <textarea
            id="field-note"
            defaultValue={(meta?.note as string) ?? ""}
            placeholder="Add a helpful note for users..."
            className="flex h-[108px] w-full rounded-md border-2 border-[#E5E7EB] bg-white px-3 py-2 text-sm transition-colors placeholder:text-muted-foreground focus:outline-none focus:border-primary"
          />
        </div>
      </div>
    </div>
  );
}

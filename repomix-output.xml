<file path="src/features/fields/components/interfaces/M2oInterfaceForm.tsx">
"use client";

import { useState, useEffect, useRef, useCallback } from "react";
import { ChevronDown } from "lucide-react";
import { useCollections } from "@/lib/query/hooks/collections";
import { useAppStore } from "@/stores/appStore";
import type { FieldResponse } from "@/lib/api/fields";
import type { CollectionResponse } from "@/types/api";
import TreeNode, { type FieldNode } from "@/shared/ui/tree-select";

export default function M2oInterfaceForm({
  relation,
  m2oOptions,
  onM2oOptionsChange,
}: {
  relation: import("@/lib/api/fields").RelationDto | null;
  m2oOptions?: { displayTemplate?: string; enableCreate?: boolean; enableSelect?: boolean };
  onM2oOptionsChange?: (opts: { displayTemplate?: string; enableCreate?: boolean; enableSelect?: boolean }) => void;
}) {
  const [displayOpen, setDisplayOpen] = useState(false);
  const displayRef = useRef<HTMLDivElement>(null);
  const [enableCreate, setEnableCreate] = useState(m2oOptions?.enableCreate ?? true);
  const [enableSelect, setEnableSelect] = useState(m2oOptions?.enableSelect ?? true);
  const { data: allCollections } = useCollections();
  const allFields = useAppStore((s) => s.fields);

  const relatedCollectionName = relation?.relatedCollection || "";
  const relatedCollection = allCollections?.find((c) => c.meta.name === relatedCollectionName);
  const relatedFields = allFields.filter((f) => f.meta.collectionId === relatedCollection?.meta.id) as FieldResponse[];

  const buildFieldTree = useCallback((fields: FieldResponse[], prefix = "", depth = 0): FieldNode[] => {
    if (depth > 2 || !fields) return [];
    const tree: FieldNode[] = [];
    for (const f of fields) {
      const fullName = prefix ? `${prefix}.${f.field}` : f.field;
      const node: FieldNode = { name: fullName };
      if (f.meta.special === "m2o") {
        const relOpts = f.meta.options as Record<string, unknown> | null;
        const relColName = relOpts?.relatedCollection as string | undefined;
        if (relColName) {
          const relCol = allCollections?.find((c) => c.meta.name === relColName);
          const childFields = allFields.filter((f) => f.meta.collectionId === relCol?.meta.id) as FieldResponse[];
          if (childFields.length > 0) {
            node.children = buildFieldTree(childFields, fullName, depth + 1);
          }
        }
      }
      tree.push(node);
    }
    return tree;
  }, [allCollections]);

  const fieldTree = buildFieldTree(relatedFields);

  const existingTemplate = m2oOptions?.displayTemplate || "";
  const selectedFields = new Set(
    existingTemplate.match(/\{\{(.+?)\}\}/g)?.map((m) => m.slice(2, -2)) ?? [],
  );

  const [selectedDisplayFields, setSelectedDisplayFields] = useState<Set<string>>(selectedFields);
  const [expandedNodes, setExpandedNodes] = useState<Set<string>>(new Set());
  const onM2oOptionsChangeRef = useRef(onM2oOptionsChange);
  onM2oOptionsChangeRef.current = onM2oOptionsChange;

  const buildTemplate = (fields: Set<string>) =>
    Array.from(fields).map((f) => `{{${f}}}`).join("");

  useEffect(() => {
    const tpl = buildTemplate(selectedDisplayFields);
    onM2oOptionsChangeRef.current?.({
      displayTemplate: tpl || undefined,
      enableCreate,
      enableSelect,
    });
  }, [selectedDisplayFields, enableCreate]);

  useEffect(() => {
    function handleClickOutside(e: MouseEvent) {
      if (displayRef.current && !displayRef.current.contains(e.target as Node)) setDisplayOpen(false);
    }
    document.addEventListener("mousedown", handleClickOutside);
    return () => document.removeEventListener("mousedown", handleClickOutside);
  }, []);

  const toggleField = (fieldName: string) => {
    setSelectedDisplayFields((prev) => {
      const next = new Set(prev);
      if (next.has(fieldName)) next.delete(fieldName);
      else next.add(fieldName);
      return next;
    });
  };

  return (
    <div className="flex flex-col gap-4">
      <div>
        <label className="mb-1.5 block text-sm font-medium text-[#111827]">Display Template</label>
        <div className="relative" ref={displayRef}>
          <button
            type="button"
            onClick={() => setDisplayOpen(!displayOpen)}
            className="flex h-[54px] w-full items-center justify-between rounded-md border-2 border-[#E5E7EB] bg-white px-3 text-sm focus:border-primary focus:outline-none"
          >
            <span className={selectedDisplayFields.size === 0 ? "text-[#9CA3AF]" : "text-[#111827]"}>
              {selectedDisplayFields.size === 0
                ? "Select fields..."
                : `${selectedDisplayFields.size} field${selectedDisplayFields.size > 1 ? "s" : ""} selected`}
            </span>
            <ChevronDown className={`h-4 w-4 text-[#9CA3AF] transition-transform ${displayOpen ? "rotate-180" : ""}`} />
          </button>
          {displayOpen && fieldTree.length > 0 && (
            <div className="absolute z-50 mt-1 w-full rounded-md border border-[#E5E7EB] bg-white py-1 shadow-lg max-h-60 overflow-y-auto">
              {fieldTree.map((node) => (
                <TreeNode
                  key={node.name}
                  node={node}
                  depth={0}
                  selectedDisplayFields={selectedDisplayFields}
                  expandedNodes={expandedNodes}
                  onToggleField={toggleField}
                  onToggleExpand={(name) => {
                    setExpandedNodes((prev) => {
                      const next = new Set(prev);
                      if (next.has(name)) next.delete(name);
                      else next.add(name);
                      return next;
                    });
                  }}
                />
              ))}
            </div>
          )}
          {selectedDisplayFields.size > 0 && (
            <div className="mt-1.5 rounded-md bg-[#F9FAFB] px-2.5 py-1 font-mono text-xs text-[#6B7280]">
              {buildTemplate(selectedDisplayFields)}
            </div>
          )}
        </div>
      </div>
      <div className="flex flex-col gap-3">
        <label className="flex items-center gap-2 cursor-pointer">
          <input
            type="checkbox"
            checked={enableCreate}
            onChange={(e) => setEnableCreate(e.target.checked)}
            className="h-4 w-4 rounded border-[#E5E7EB] text-primary focus:ring-primary"
          />
          <span className="text-sm font-medium text-[#111827]">Enable Create button</span>
        </label>
        <label className="flex items-center gap-2 cursor-pointer">
          <input
            type="checkbox"
            checked={enableSelect}
            onChange={(e) => setEnableSelect(e.target.checked)}
            className="h-4 w-4 rounded border-[#E5E7EB] text-primary focus:ring-primary"
          />
          <span className="text-sm font-medium text-[#111827]">Enable Select button</span>
        </label>
      </div>
    </div>
  );
}
</file>


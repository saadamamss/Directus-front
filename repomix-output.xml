<file path="src/features/items/components/ItemForm/fields/M2OField.tsx">
"use client";

import { FolderOpen, Plus, X } from "lucide-react";
import { useItem } from "@/lib/query/hooks/items";
import type { FieldResponse } from "@/lib/api/fields";

function renderTemplate(template: string, item: Record<string, unknown>): string {
  return template.replace(/\{\{(.+?)\}\}/g, (_, key: string) => {
    const parts = key.trim().split(".");
    let value: unknown = item;
    for (const part of parts) {
      if (value && typeof value === "object") {
        value = (value as Record<string, unknown>)[part];
      } else {
        return `{{${key}}}`;
      }
    }
    return value != null ? String(value) : `{{${key}}}`;
  });
}

interface Props {
  field: FieldResponse;
  value: unknown;
  onChange: (val: unknown) => void;
}

export default function M2OField({ field, value, onChange }: Props) {
  const opts = field.meta.options as Record<string, unknown> | null;
  const relatedCollection = (opts?.relatedCollection as string) || "";
  const displayTemplate = (opts?.displayTemplate as string) || "";
  const enableCreate = opts?.enableCreate !== false;
  const enableSelect = opts?.enableSelect !== false;
  const parentId = typeof value === "number" ? value : 0;
  const { data: parentItem } = useItem(relatedCollection, parentId);

  const displayText = parentItem && displayTemplate
    ? renderTemplate(displayTemplate, parentItem as Record<string, unknown>)
    : null;

  return (
    <div className="space-y-2 col-span-2">
      <label className="text-sm font-medium text-[#111827]">
        {field.meta.label}
        {field.meta.required && <span className="ml-1 text-red-500">*</span>}
      </label>
      <div className="flex items-center gap-3">
        <div className="flex-1 rounded-md border-2 border-[#E5E7EB] bg-white px-3 py-2 text-sm text-[#111827]">
          {parentItem ? (
            <span>{displayText ?? String(parentItem.name ?? parentId)}</span>
          ) : parentId ? (
            <span className="text-[#6B7280]">{parentId}</span>
          ) : (
            <span className="text-[#9CA3AF]">—</span>
          )}
        </div>
        {(enableCreate || enableSelect) && (
          <>
            {enableCreate && (
              <button type="button"
                onClick={() => {
                  const url = `/admin/content/${relatedCollection}%2B`;
                  window.open(url, "_blank");
                }}
                className="flex items-center gap-1.5 rounded-md bg-primary px-3 py-2 text-sm font-medium text-white hover:bg-[#e04342]">
                <Plus className="h-4 w-4" /> Create
              </button>
            )}
            {enableSelect && (
              <button type="button"
                onClick={() => {
                  const url = `/admin/content/${relatedCollection}`;
                  window.open(url, "_blank");
                }}
                className="flex items-center gap-1.5 rounded-md border border-[#CBD5E1] bg-white px-3 py-2 text-sm font-medium text-[#475569] hover:bg-[#F1F5F9]">
                <FolderOpen className="h-4 w-4" /> Select
              </button>
            )}
          </>
        )}
        {parentId && (
          <button type="button" onClick={() => onChange(null)}
            className="flex h-9 w-9 items-center justify-center rounded-md text-[#9CA3AF] hover:text-red-500">
            <X className="h-4 w-4" />
          </button>
        )}
      </div>
      {field.meta.note && <p className="text-xs text-[#9CA3AF]">{field.meta.note}</p>}
    </div>
  );
}

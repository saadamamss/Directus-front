          ],
          "body": "{\n    \"success\": true,\n    \"message\": \"Operation successful\",\n    \"code\": \"SUCCESS\",\n    \"data\": [\n        { \"id\": 0, \"value\": \"STRING\" },\n        { \"id\": 1, \"value\": \"TEXT\" },\n        { \"id\": 2, \"value\": \"NUMBER\" },\n        { \"id\": 3, \"value\": \"BOOLEAN\" },\n        { \"id\": 4, \"value\": \"DATE\" }\n    ]\n}"
